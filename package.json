{
  "name": "m3u-playlist-editor",
  "version": "1.0.0",
  "description": "M3U Playlist Editor - IPTV playlist management REST API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage jest",
    "test:watch": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage jest --watch",
    "test:property": "cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage jest --testPathPattern=property",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "seed:demo": "node scripts/seed-demo.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "node",
        "node-addons"
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.property.js"
    ]
  }
}
